      "source": [
        "def build_frequency_tensor_batch(img_tensor_batch: torch.Tensor) -> torch.Tensor:\n",
        "    gray = img_tensor_batch.mean(dim=1, keepdim=True)\n",
        "\n",
        "    fft = torch.fft.fft2(gray)\n",
        "    fft = torch.fft.fftshift(fft, dim=(-2, -1))\n",
        "    magnitude = torch.log1p(torch.abs(fft))\n",
        "\n",
        "    b, c, h, w = magnitude.shape\n",
        "    magnitude_view = magnitude.view(b, -1)\n",
        "    mean = magnitude_view.mean(dim=1).view(b, 1, 1, 1)\n",
        "    std = magnitude_view.std(dim=1, unbiased=False).view(b, 1, 1, 1)\n",
        "\n",
        "    magnitude = (magnitude - mean) / (std + 1e-6)\n",
        "\n",
        "    return magnitude.repeat(1, 3, 1, 1)"
      ]
    },
    {
